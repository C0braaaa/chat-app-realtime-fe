{
  "expo": {
    "name": "C Chat",
    "slug": "c-chat",
    "scheme": "c-chat",
    "version": "1.1.5 ",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash_image.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c1917"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cho phép C Chat truy cập Camera.",
        "NSMicrophoneUsageDescription": "Cho phép C Chat truy cập Micro."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.cobraa.cchat",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "81e69662-5290-4dae-b3ec-af9d1ceed193"
      },
      "EXPO_PUBLIC_APP_ID": "682284813",
      "EXPO_PUBLIC_APP_SIGN": "b41af788c9e627ba9d8e99120844b5e698fe9c3939dc52de08edb0b5670f253f"
    }
  }
}